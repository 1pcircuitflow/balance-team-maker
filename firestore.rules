rules_version = '2';

// Firebase Auth 통합 완료 후 배포할 규칙
// ⚠️ 사용자들이 새 버전(Firebase Auth 포함)으로 업데이트한 후 배포할 것
// 배포 전까지는 기존 allow read, write: if true 유지 (Firebase Console에서 관리)

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{userId}: 인증된 사용자만 읽기, 본인 문서만 쓰기
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // rooms/{roomId}: 누구나 읽기, 인증 사용자만 생성/수정, 삭제 불가
    match /rooms/{roomId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;

      // rooms/{roomId}/messages/{msgId}: 인증 사용자만 읽기/생성
      match /messages/{msgId} {
        allow read, create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // venues/{placeId}: 누구나 읽기, 인증 사용자만 쓰기
    match /venues/{placeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // announcements: 누구나 읽기, 쓰기 불가 (관리자는 콘솔에서 직접)
    match /announcements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // appConfig: 누구나 읽기, 쓰기 불가
    match /appConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
